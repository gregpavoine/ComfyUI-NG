{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfyui-ng.org/schemas/nodes/sample_flux.input.json",
  "title": "FLUX Sample Input",
  "type": "object",
  "properties": {
    "prompt": {"type": "string", "default": ""},
    "negative_prompt": {"type": "string", "default": ""},
    "width": {"type": "integer", "minimum": 64, "maximum": 2048, "default": 1024},
    "height": {"type": "integer", "minimum": 64, "maximum": 2048, "default": 1024},
    "steps": {"type": "integer", "minimum": 1, "maximum": 100, "default": 28},
    "guidance": {"type": "number", "minimum": 0, "maximum": 20, "default": 3.5},
    "seed": {"type": "integer", "minimum": 0, "maximum": 4294967295, "default": 42},
    "num_images": {"type": "integer", "minimum": 1, "maximum": 4, "default": 1}
  },
  "required": [],
  "additionalProperties": false
}