{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.comfyng.local/nodes/ng.image.save/input/1",
  "title": "NG Save Image inputs",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "image": {
      "type": "string",
      "x-comfyng-type": "NG_IMAGE@1"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "enum": [
        "png",
        "jpeg",
        "webp"
      ]
    }
  },
  "required": [
    "image",
    "path"
  ],
  "x-comfyng-optional": [
    "format"
  ]
}
