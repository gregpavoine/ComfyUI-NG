{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.comfyng.local/nodes/ng.image.crop/input/1",
  "title": "NG Crop Image inputs",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "image": {
      "type": "string",
      "x-comfyng-type": "NG_IMAGE@1"
    },
    "x": {
      "type": "integer",
      "minimum": 0
    },
    "y": {
      "type": "integer",
      "minimum": 0
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": [
    "image",
    "x",
    "y",
    "width",
    "height"
  ]
}
