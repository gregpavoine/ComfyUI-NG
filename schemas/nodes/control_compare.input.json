{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.comfyng.local/nodes/ng.control.compare/input/1",
  "title": "NG Compare inputs",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "left": {
      "type": [
        "null",
        "boolean",
        "object",
        "array",
        "number",
        "string",
        "integer"
      ]
    },
    "right": {
      "type": [
        "null",
        "boolean",
        "object",
        "array",
        "number",
        "string",
        "integer"
      ]
    },
    "operator": {
      "type": "string",
      "enum": [
        "eq",
        "ne",
        "lt",
        "lte",
        "gt",
        "gte"
      ]
    }
  },
  "required": [
    "left",
    "right",
    "operator"
  ]
}
