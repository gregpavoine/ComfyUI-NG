{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.comfyng.local/nodes/ng.sample.run/input/1",
  "title": "NG Sampler inputs",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "model": {
      "type": "string",
      "x-comfyng-type": "NG_MODEL@1"
    },
    "conditioning": {
      "type": "string",
      "x-comfyng-type": "NG_CONDITIONING@1"
    },
    "latent": {
      "type": "string",
      "x-comfyng-type": "NG_LATENT@1"
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "steps": {
      "type": "integer",
      "minimum": 1
    },
    "guidance": {
      "type": "number",
      "minimum": 0
    },
    "sampler": {
      "type": "string",
      "minLength": 1
    },
    "scheduler": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "model",
    "conditioning",
    "latent",
    "seed",
    "steps",
    "guidance",
    "sampler",
    "scheduler"
  ]
}
