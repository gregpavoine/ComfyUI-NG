{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.comfyng.local/nodes/ng.latent.resize/input/1",
  "title": "NG Latent Resize inputs",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "latent": {
      "type": "string",
      "x-comfyng-type": "NG_LATENT@1"
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "nearest",
        "bilinear",
        "bicubic"
      ]
    }
  },
  "required": [
    "latent",
    "width",
    "height"
  ]
}
